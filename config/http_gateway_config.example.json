{
  "schema_version": "1.0",
  "security_boundary": "HTTP remote mode. Expose only through HTTPS tunnel/reverse proxy with authentication. Do not expose unauthenticated HTTP.",
  "guardian_root": "F:\\Projects\\MCPGuardian",
  "enable_rule_mutation": false,
  "http": {
    "host": "127.0.0.1",
    "port": 8000,
    "path": "/mcp",
    "require_bearer_token": true,
    "health_endpoint": true
  },
  "paths": {
    "runs_dir": "runs",
    "active_rules": "config/active_rules.json",
    "pending_rules": "config/pending_rules.json",
    "rule_history": "config/rule_history.jsonl"
  },
  "allowed_roots": [
    "."
  ],
  "gateway": {
    "tool_separator": "__",
    "default_tool_timeout_seconds": 30,
    "resilience_note": "tools/call retry is disabled by default unless retry_tool_calls=true and safe_retry_tools matches the tool name."
  },
  "backends": {
    "desktop_commander": {
      "command": "node",
      "args": [
        "C:/path/to/desktop-commander/server.js"
      ],
      "tool_prefix": "dc",
      "timeout_seconds": 30,
      "disabled": true,
      "resilience": {
        "max_retries": 1,
        "retry_delay_base_seconds": 0.25,
        "retry_delay_max_seconds": 3.0,
        "retry_backoff_multiplier": 2.0,
        "retry_tool_calls": false,
        "safe_retry_tools": [],
        "restart_on_failure": true,
        "restart_on_timeout": true,
        "kill_process_tree": true,
        "circuit_breaker_failure_threshold": 3,
        "circuit_breaker_recovery_seconds": 30
      }
    },
    "filesystem": {
      "command": "node",
      "args": [
        "C:/path/to/filesystem/server.js"
      ],
      "tool_prefix": "fs",
      "timeout_seconds": 30,
      "disabled": true,
      "resilience": {
        "max_retries": 1,
        "retry_delay_base_seconds": 0.25,
        "retry_delay_max_seconds": 3.0,
        "retry_backoff_multiplier": 2.0,
        "retry_tool_calls": false,
        "safe_retry_tools": [],
        "restart_on_failure": true,
        "restart_on_timeout": true,
        "kill_process_tree": true,
        "circuit_breaker_failure_threshold": 3,
        "circuit_breaker_recovery_seconds": 30
      }
    }
  },
  "resilience": {
    "note": "Per-backend resilience is configured under each backend.resilience block."
  }
}
